package(default_visibility = ["//visibility:public"])

licenses(["notice"])

exports_files(["LICENSE.txt"])

load("@bazel_skylib//rules:expand_template.bzl", "expand_template")

expand_template(
    name = "nccl_header_version",
    out = "src/nccl.h",
    substitutions = {
        "${nccl:Major}": "%{major}",
        "${nccl:Minor}": "%{minor}",
        "${nccl:Patch}": "%{patch}",
        "${nccl:Suffix}": "\"\"",
        "${nccl:Version}": "%{version_code}",
    },
    template = "src/nccl.h.in",
)

cc_library(
    name = "doca_hdrs",
    hdrs = glob(["src/transport/net_ib/gdaki/doca-gpunetio/include/**"]),
    strip_include_prefix = "src/transport/net_ib/gdaki/doca-gpunetio/include",
    include_prefix = "doca_gpunetio",
)

cc_library(
    name = "nccl_generated_h",
    hdrs = [":nccl_header_version"],
    strip_include_prefix = "src",
)

cc_library(
    name = "nccl_hdrs",
    hdrs = glob(
        include = ["src/include/**"],
        exclude = ["src/include/plugin/**"],
    ),
    strip_include_prefix = "src/include",
    deps = [":nccl_generated_h", ":doca_hdrs"],
)

filegroup(
    name = "ir_wrapper_srcs",
    srcs = glob(["bindings/ir/*.h"]),
)
