From 1f3fbb746c3ed80d26031835f230ec414f2560fb Mon Sep 17 00:00:00 2001
From: Kanish Anand <kanishanand@google.com>
Date: Mon, 15 Jun 2026 07:07:14 -0700
Subject: [PATCH] Add `enableHloShardingV3` check for `HloShardingV3` fallback
 to avoid spam of logs

PiperOrigin-RevId: 932439953
---
 xla/service/spmd/shardy/shardy_xla_pass.cc | 4 ++--
 1 file changed, 2 insertions(+), 2 deletions(-)

diff --git a/xla/service/spmd/shardy/shardy_xla_pass.cc b/xla/service/spmd/shardy/shardy_xla_pass.cc
index bb388e518a7fd..021d7971ce009 100644
--- a/xla/service/spmd/shardy/shardy_xla_pass.cc
+++ b/xla/service/spmd/shardy/shardy_xla_pass.cc
@@ -371,8 +371,8 @@ absl::Status runShardingPropagation(HloModule* hloModule,
   // 6 months compatibility window.
   // TODO (b/519501636): Remove this fallback once 6 months compatibility window
   // for ifrt has passed in Nov'2026.
-  if (xla::sdy::hasFrontendMhloShardings(mlirModule) ||
-      xla::sdy::hasFrontendMeshes(mlirModule)) {
+  if (enableHloShardingV3 && (xla::sdy::hasFrontendMhloShardings(mlirModule) ||
+                              xla::sdy::hasFrontendMeshes(mlirModule))) {
     // Fallback checks for mhlo sharding is not sufficient, we need to check for
     // meshes as well to handle shard map cases.
     LOG(WARNING)
