diff --git a/third_party/shardy/reshard_fix.patch b/third_party/shardy/reshard_fix.patch
new file mode 100644
--- /dev/null
+++ b/third_party/shardy/reshard_fix.patch
@@ -0,0 +1,14 @@
+diff --git a/shardy/dialect/sdy/transforms/export/explicit_reshards_util.cc b/shardy/dialect/sdy/transforms/export/explicit_reshards_util.cc
