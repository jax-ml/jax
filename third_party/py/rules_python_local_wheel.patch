+def _collect_local_wheels(module_ctx, pip_attr, python_version):
+    local_wheel_workspaces = pip_attr.local_wheel_workspaces
+    if not local_wheel_workspaces:
+        return {}
+
+    py_ver_marker = "-cp%s-" % python_version.replace(".", "")
+    py_major_ver_marker = "-py%s-" % python_version.split(".")[0]
+    wheels = {}
+
+    for workspace_label in local_wheel_workspaces:
+        workspace_path = module_ctx.path(workspace_label)
+        dist_folder = pip_attr.local_wheel_dist_folder or "dist"
+        dist_folder_path = workspace_path.dirname.get_child(dist_folder)
+        if dist_folder_path.exists:
+            for wheel in dist_folder_path.readdir():
+                bn = wheel.basename
+                if not bn.endswith(".whl"):
+                    continue
+                if bn.find(py_ver_marker) < 0 and bn.find(py_major_ver_marker) < 0:
+                    continue
+                if not _basic_wildcard_match(bn, pip_attr.local_wheel_inclusion_list, True, False):
+                    continue
+                if not _basic_wildcard_match(bn, pip_attr.local_wheel_exclusion_list, False, True):
+                    continue
+
+                name_components = bn.split("-")
+                package_name = name_components[0]
+                for name_component in name_components[1:]:
+                    if name_component[0].isdigit():
+                        break
+                    package_name += "-" + name_component
+
+                norm_name = normalize_name(package_name)
+                latest_wheel = wheels.get(norm_name)
+                if not latest_wheel or latest_wheel.basename < wheel.basename:
+                    wheels[norm_name] = wheel
+
+    return wheels
+
+def _basic_wildcard_match(name, patterns, expected_match_result, match_all):
+    match = False
+    for pattern in patterns:
+        match = False
+        if pattern.startswith("*") and pattern.endswith("*"):
+            match = name.find(pattern[1:-1]) >= 0
+        elif pattern.startswith("*"):
+            match = name.endswith(pattern[1:])
+        elif pattern.endswith("*"):
+            match = name.startswith(pattern[:-1])
+        else:
+            match = name == pattern
+
+        if match_all:
+            if match != expected_match_result:
+                return False
+        elif match == expected_match_result:
+            return True
+
+    return match == expected_match_result
